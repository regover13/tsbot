# =============================================================================
# TSBot Konfiguration – Template
#
# Kopieren und ausfüllen:
#   cp config/config.example.env config/config.env
#   nano config/config.env
#
# WICHTIG: config.env enthält Secrets und ist in .gitignore eingetragen!
# =============================================================================

# ── Anthropic / Claude ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-HIER_DEINEN_KEY_EINTRAGEN
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# ── TeamSpeak ServerQuery ─────────────────────────────────────
TS_HOST=127.0.0.1
TS_QUERY_PORT=10011
TS_QUERY_USER=serveradmin
TS_QUERY_PASS=DEIN_SERVERQUERY_PASSWORT
TS_SERVER_ID=1
# Kanal-ID der Konferenz (0 = alle Kanäle tracken)
TS_CHANNEL_ID=42
# Hostname / IP des TS3-Servers für den Client
TS_PORT=9987

# ── Whisper ───────────────────────────────────────────────────
# CPU-VPS: medium (1,5 GB, ~8-15 Min/h Audio) empfohlen
# Schwache Server: small (460 MB, schneller aber ungenauer)
# Mit GPU: large (2,9 GB, beste Qualität)
WHISPER_MODEL=medium

# ── Sprechertrennung (Diarization) ────────────────────────────
# USE_DIARIZATION=true aktiviert whisperx + pyannote.audio.
# Jeder Sprecher bekommt ein [SPRECHER_0], [SPRECHER_1]-Tag.
# Claude versucht die Sprecher beim Protokollieren den Teilnehmern zuzuordnen.
#
# Voraussetzungen:
#   1. pip install whisperx  (bereits in requirements.txt)
#   2. Kostenlosen HuggingFace-Account erstellen: https://huggingface.co
#   3. Token generieren: https://huggingface.co/settings/tokens
#   4. Einmalig Lizenz akzeptieren:
#      https://huggingface.co/pyannote/speaker-diarization-3.1
#      https://huggingface.co/pyannote/segmentation-3.0
#
# Mehraufwand auf CPU-VPS: +20-40% Rechenzeit gegenüber plain Whisper.
USE_DIARIZATION=false
HF_TOKEN=hf_DEIN_HUGGINGFACE_TOKEN

# ── Audio (PulseAudio) ────────────────────────────────────────
PULSE_SINK=tsbot_sink

# ── Datenpfade ────────────────────────────────────────────────
DATA_DIR=/opt/tsbot/data
AGENDA_PATH=/opt/tsbot/data/agenda.txt
TS_CLIENT_DIR=/home/tsbot/TeamSpeak3

# ── Web-API ───────────────────────────────────────────────────
API_PORT=8080
# HTTP Basic Auth Credentials für das Web-Interface
API_USER=admin
API_SECRET=SICHERES_PASSWORT_HIER_EINTRAGEN
